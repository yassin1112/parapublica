# Local MongoDB (default)
MONGODB_URI=mongodb://127.0.0.1:27017/parapublic

# MongoDB Atlas — prefer including the database name:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/parapublic?retryWrites=true&w=majority
#
# If "querySrv ECONNREFUSED" on Windows: use Atlas "Standard" connection string (mongodb://…)
# or set PC DNS to 8.8.8.8 — the app also tries Google DNS for mongodb+srv automatically.

# Optional locally — default secret is used if omitted
# JWT_SECRET=change-this-secret-in-production
PORT=3000

# Optional — primary admin (npm run seed:admin)
# ADMIN_EMAIL=admin-para@gmail.com
# ADMIN_PASSWORD=23698716

# Vercel: add MONGODB_URI (required). JWT_SECRET is optional.
# Then run seed once locally against the same Atlas DB: npm run seed
